# Copy this file to .env and update with your machine's IP address
API_URL=http://YOUR_IP_ADDRESS:3000/api/v1

# Stripe test publishable key (pk_test_...) — get it from your Stripe dashboard.
# This is safe to bundle with the app (it's the publishable key, not the secret key).
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
